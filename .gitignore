# ─── Secrets ────────────────────────────────────────────────
# Never commit API keys. Use .env (loaded by python-dotenv).
# .env.example IS committed as a template; the real .env is not.
.env
.env.*
!.env.example

# ─── Python ─────────────────────────────────────────────────
__pycache__/
*.pyc
.venv/
venv/

# ─── App data ───────────────────────────────────────────────
# Regenerable from seed via load_data.py
backend/manufacturing.db

# Large seed data — uncomment if you don't want to commit it
# data/seed_data.json

# ─── Editors / OS ───────────────────────────────────────────
.DS_Store
.vscode/
.idea/
